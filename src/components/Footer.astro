---
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__columns">
      <div class="footer__col">
        <h3 class="footer__heading">Quick links</h3>
        <ul class="footer__links">
          <li><a href="/collections?category=abstracts">Abstracts</a></li>
          <li><a href="/collections?category=interpretations">Interpretations</a></li>
          <li><a href="/about">About me</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/shipping">Shipping, returns etc</a></li>
          <li><a href="/copyright">Copyright</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Subscribe for alerts about new Collections</h3>
        <form class="footer__newsletter" action="#" method="post">
          <div class="footer__newsletter-field">
            <input type="email" name="email" placeholder="Email" required aria-label="Email address" />
            <button type="submit" aria-label="Subscribe">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__social">
        <a href="https://facebook.com/kitchingart" aria-label="Facebook" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://instagram.com/kitchingart" aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>

      <div class="footer__payment">
        <span class="footer__payment-label">Accepted payments:</span>
        <span class="footer__payment-icons">Visa, Mastercard, Amex, PayPal, Klarna, Apple Pay, Google Pay</span>
      </div>

      <p class="footer__copyright">
        &copy; {new Date().getFullYear()} <a href="/">KitchingArt</a>. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-body-bg);
    border-top: 1px solid var(--color-border);
    padding: 3rem 0 2rem;
    margin-top: 3rem;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .footer__heading {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    color: var(--color-heading-text);
  }

  .footer__links li {
    margin-bottom: 0.5rem;
  }

  .footer__links a {
    font-size: 0.9rem;
    color: var(--color-body-text);
    transition: color 0.15s;
  }

  .footer__links a:hover {
    color: var(--color-heading-text);
  }

  .footer__newsletter-field {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    max-width: 360px;
  }

  .footer__newsletter-field input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    outline: none;
  }

  .footer__newsletter-field button {
    padding: 0.75rem 1rem;
    color: var(--color-body-text);
    transition: color 0.15s;
  }

  .footer__newsletter-field button:hover {
    color: var(--color-heading-text);
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-body-text);
  }

  .footer__social {
    display: flex;
    gap: 1rem;
  }

  .footer__social a {
    color: var(--color-body-text);
    transition: color 0.15s;
  }

  .footer__social a:hover {
    color: var(--color-heading-text);
  }

  .footer__payment {
    font-size: 0.75rem;
  }

  .footer__payment-label {
    font-weight: 600;
    margin-right: 0.5rem;
  }

  .footer__copyright a {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer__columns {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
