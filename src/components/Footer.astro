---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Company Info -->
      <div class="footer-col">
        <div class="footer-logo">
          <div class="footer-logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="var(--white)" stroke="none"><path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/></svg>
          </div>
          <div>
            <span class="footer-logo-name">Roof Repairs</span>
            <span class="footer-logo-location">Manchester</span>
          </div>
        </div>
        <p class="footer-desc">
          Trusted local roofers serving Manchester and surrounding areas. Fully insured, experienced, and committed to quality workmanship on every job.
        </p>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4>Our Services</h4>
        <ul>
          <li><a href="/services/">Roof Repairs</a></li>
          <li><a href="/services/">New Roof Installation</a></li>
          <li><a href="/services/">Flat Roofing</a></li>
          <li><a href="/services/">Chimney Repairs</a></li>
          <li><a href="/services/">Guttering</a></li>
          <li><a href="/services/">Emergency Roofing</a></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/services/">Services</a></li>
          <li><a href="/about/">About Us</a></li>
          <li><a href="/reviews/">Reviews</a></li>
          <li><a href="/gallery/">Gallery</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4>Contact Us</h4>
        <ul class="contact-list">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <a href="tel:01612345678">0161 234 5678</a>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <a href="mailto:info@roofrepairsmanchester.co.uk">info@roofrepairsmanchester.co.uk</a>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span>Manchester, Greater Manchester</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            <span>Mon–Sat: 8am–6pm</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Roof Repairs Manchester. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark-bg);
    color: #ccc;
    padding: 60px 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
    gap: 40px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 15px;
  }

  .footer-logo-icon {
    width: 40px;
    height: 40px;
    background: var(--red);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .footer-logo-name {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    text-transform: uppercase;
    color: var(--white);
    line-height: 1.1;
  }

  .footer-logo-location {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--red);
    letter-spacing: 2px;
  }

  .footer-desc {
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .footer-col h4 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.15rem;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 20px;
    position: relative;
    padding-bottom: 10px;
  }

  .footer-col h4::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 30px;
    height: 3px;
    background: var(--red);
    border-radius: 2px;
  }

  .footer-col ul li {
    margin-bottom: 10px;
  }

  .footer-col ul li a {
    color: #ccc;
    transition: color 0.3s;
    font-size: 0.9rem;
  }

  .footer-col ul li a:hover {
    color: var(--yellow);
  }

  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
  }

  .contact-list li svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--red);
  }

  .footer-bottom {
    margin-top: 40px;
    padding: 20px 0;
    border-top: 1px solid #333;
    text-align: center;
    font-size: 0.85rem;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
