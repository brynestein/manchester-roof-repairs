---
const navItems = [
  {
    label: 'Abstracts',
    children: [
      { label: 'The Feeling Right Now Collection', href: '/collections/feeling-right-now' },
      { label: 'The Misinformation Collection', href: '/collections/misinformation' },
      { label: 'The Viewpoints Collection', href: '/collections/the-viewpoints-collection' },
      {
        label: 'The Fractures series',
        children: [
          { label: 'The Fractured Matrix Collection', href: '/collections/the-fractured-matrix-collection' },
          { label: 'Long Fractured Matrix Collection', href: '/collections/long-fractured-matrix-collection' },
        ],
      },
      { label: 'The Experience of Simply Being Collection', href: '/collections/experience-of-being' },
      { label: 'Solo Abstracts Collection #1', href: '/collections/solo-abstracts-1' },
      { label: 'All Abstract Collections', href: '/collections?category=abstracts' },
    ],
  },
  {
    label: 'Interpretations',
    children: [
      { label: 'The Monx Collection', href: '/collections/the-monx-collection' },
      { label: 'The Dancing Collection', href: '/collections/the-dancing-collection' },
      { label: 'The Seer Collection', href: '/collections/the-seer-collection' },
      { label: 'The Rumination Collection', href: '/collections/rumination' },
      { label: 'Solo Interpretations #1', href: '/collections/interpretations-collection-1' },
      {
        label: 'The Late for Living series',
        children: [
          { label: 'Late to realise your place', href: '/collections/late-to-realise-your-place' },
          { label: 'Late to see the truth', href: '/collections/late-to-see-the-truth' },
        ],
      },
      { label: 'All Interpretations Collections', href: '/collections?category=interpretations' },
    ],
  },
  {
    label: 'Photographs',
    children: [
      { label: 'The Images of Budapest Collection', href: '/collections/the-images-of-budapest-collection' },
    ],
  },
  {
    label: 'Everything',
    children: [
      { label: 'All Collections', href: '/collections' },
    ],
  },
  {
    label: 'Info',
    children: [
      { label: 'About me', href: '/about' },
      { label: 'Contact', href: '/contact' },
      { label: 'Shipping, returns etc', href: '/shipping' },
      { label: 'Why canvas prints?', href: '/why-canvas-prints' },
    ],
  },
];
---

<header class="header">
  <div class="header__inner">
    <button class="header__menu-btn" id="menu-toggle" aria-label="Open menu" aria-expanded="false">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <a href="/" class="header__logo" aria-label="KitchingArt - Home">
      <span class="logo-text">K<span class="dot dot--pink">i</span>tch<span class="dot dot--yellow">i</span>ng<span class="dot dot--magenta">a</span>rt</span>
    </a>

    <nav class="header__nav" id="desktop-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class="nav-item">
          <button class="nav-item__trigger" aria-expanded="false">
            {item.label}
            <svg class="nav-item__arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 4.5L6 7.5L9 4.5" />
            </svg>
          </button>
          {item.children && (
            <div class="nav-dropdown">
              {item.children.map((child: any) => (
                child.href ? (
                  <a href={child.href} class="nav-dropdown__link">{child.label}</a>
                ) : (
                  <div class="nav-dropdown__group">
                    <span class="nav-dropdown__group-title">{child.label}</span>
                    {child.children?.map((sub: any) => (
                      <a href={sub.href} class="nav-dropdown__link nav-dropdown__link--sub">{sub.label}</a>
                    ))}
                  </div>
                )
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <div class="header__actions">
      <button class="header__action-btn" aria-label="Search">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </button>
      <a href="/account" class="header__action-btn" aria-label="Account">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
      </a>
      <button class="header__action-btn header__cart-btn" id="cart-toggle" aria-label="Cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="cart-count" id="cart-count" style="display:none">0</span>
      </button>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__overlay" id="menu-overlay"></div>
    <div class="mobile-menu__drawer">
      <div class="mobile-menu__header">
        <button class="mobile-menu__close" id="menu-close" aria-label="Close menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
      <nav class="mobile-menu__nav" id="mobile-nav" aria-label="Mobile navigation">
        {navItems.map((item) => (
          <div class="mobile-nav-item">
            <button class="mobile-nav-item__trigger" data-submenu={item.label}>
              <span>{item.label}</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 18l6-6-6-6" />
              </svg>
            </button>
          </div>
        ))}
        <div class="mobile-menu__social">
          <a href="https://facebook.com/kitchingart" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://instagram.com/kitchingart" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        </div>
      </nav>

      <!-- Submenus rendered separately for slide-in effect -->
      {navItems.map((item) => (
        <div class="mobile-submenu" id={`submenu-${item.label}`} data-parent={item.label}>
          <button class="mobile-submenu__back" data-back>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7" />
            </svg>
            <span>{item.label}</span>
          </button>
          {item.children?.map((child: any) => (
            child.href ? (
              <a href={child.href} class="mobile-submenu__link">{child.label}</a>
            ) : (
              <div class="mobile-submenu__group">
                <button class="mobile-submenu__group-trigger" data-sub-submenu={child.label}>
                  <span>{child.label}</span>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 18l6-6-6-6" />
                  </svg>
                </button>
              </div>
            )
          ))}
        </div>
      ))}
    </div>
  </div>
</header>

<style>
  .header {
    background: var(--color-header-bg);
    color: var(--color-nav-text);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 2rem;
    gap: 2rem;
  }

  .header__menu-btn {
    color: var(--color-nav-text);
    display: none;
    padding: 0.5rem;
  }

  .header__logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-nav-text);
    letter-spacing: -0.02em;
  }

  .dot--pink { color: var(--color-accent-pink); }
  .dot--yellow { color: var(--color-accent-yellow); }
  .dot--magenta { color: var(--color-accent-magenta); }

  /* Desktop nav */
  .header__nav {
    display: flex;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
  }

  .nav-item {
    position: relative;
  }

  .nav-item__trigger {
    color: var(--color-nav-text-dim);
    font-size: 0.95rem;
    padding: 0.5rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    transition: color 0.2s;
  }

  .nav-item__trigger:hover {
    color: var(--color-nav-text);
  }

  .nav-item__arrow {
    transition: transform 0.2s;
  }

  .nav-item:hover .nav-item__arrow {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--color-header-bg);
    min-width: 280px;
    padding: 0.75rem 0;
    border-radius: 0 0 4px 4px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.2s;
    z-index: 50;
  }

  .nav-item:hover .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown__link {
    display: block;
    padding: 0.5rem 1.25rem;
    color: var(--color-nav-text-dim);
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .nav-dropdown__link:hover {
    color: var(--color-nav-text);
  }

  .nav-dropdown__link--sub {
    padding-left: 2rem;
  }

  .nav-dropdown__group-title {
    display: block;
    padding: 0.5rem 1.25rem;
    color: var(--color-nav-text);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Header actions */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header__action-btn {
    color: var(--color-nav-text-dim);
    padding: 0.5rem;
    transition: color 0.15s;
    position: relative;
    display: flex;
    align-items: center;
  }

  .header__action-btn:hover {
    color: var(--color-nav-text);
  }

  .cart-count {
    position: absolute;
    top: 0;
    right: -2px;
    background: var(--color-accent-pink);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 200;
    pointer-events: none;
  }

  .mobile-menu[aria-hidden="false"] {
    pointer-events: all;
  }

  .mobile-menu__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .mobile-menu[aria-hidden="false"] .mobile-menu__overlay {
    opacity: 1;
  }

  .mobile-menu__drawer {
    position: absolute;
    top: 0;
    left: 0;
    width: 340px;
    max-width: 90vw;
    height: 100%;
    background: var(--color-header-bg);
    color: var(--color-nav-text);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu[aria-hidden="false"] .mobile-menu__drawer {
    transform: translateX(0);
  }

  .mobile-menu__header {
    display: flex;
    justify-content: flex-start;
    padding: 1rem;
  }

  .mobile-menu__close {
    color: var(--color-nav-text);
    padding: 0.5rem;
  }

  .mobile-menu__nav {
    padding: 0 1rem;
    flex: 1;
  }

  .mobile-nav-item__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.75rem 0;
    color: var(--color-nav-text);
    font-size: 1.05rem;
    border-bottom: 1px solid rgba(224, 224, 193, 0.1);
  }

  .mobile-menu__social {
    display: flex;
    gap: 1rem;
    padding: 2rem 0;
    color: var(--color-nav-text-dim);
  }

  .mobile-menu__social a {
    color: inherit;
    transition: color 0.15s;
  }

  .mobile-menu__social a:hover {
    color: var(--color-nav-text);
  }

  /* Mobile submenus */
  .mobile-submenu {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-header-bg);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    padding: 1rem;
    overflow-y: auto;
  }

  .mobile-submenu.active {
    transform: translateX(0);
  }

  .mobile-submenu__back {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-nav-text-dim);
    font-size: 0.85rem;
    padding: 0.75rem 0;
    margin-bottom: 0.5rem;
  }

  .mobile-submenu__link {
    display: block;
    padding: 0.75rem 0;
    color: var(--color-nav-text);
    font-size: 1rem;
    border-bottom: 1px solid rgba(224, 224, 193, 0.1);
  }

  .mobile-submenu__group-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.75rem 0;
    color: var(--color-nav-text);
    font-size: 1rem;
    border-bottom: 1px solid rgba(224, 224, 193, 0.1);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .header__nav {
      display: none;
    }

    .header__menu-btn {
      display: flex;
    }

    .header__inner {
      padding: 0.75rem 1rem;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const menuOverlay = document.getElementById('menu-overlay');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu?.setAttribute('aria-hidden', 'false');
    menuToggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.setAttribute('aria-hidden', 'true');
    menuToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    // Close all submenus
    document.querySelectorAll('.mobile-submenu.active').forEach((el) => el.classList.remove('active'));
  }

  menuToggle?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  menuOverlay?.addEventListener('click', closeMenu);

  // Submenu navigation
  document.querySelectorAll('[data-submenu]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const name = btn.getAttribute('data-submenu');
      const submenu = document.getElementById(`submenu-${name}`);
      submenu?.classList.add('active');
    });
  });

  document.querySelectorAll('[data-back]').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.mobile-submenu')?.classList.remove('active');
    });
  });
</script>
