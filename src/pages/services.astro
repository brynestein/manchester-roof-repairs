---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';

const services = [
  {
    title: "Roof Repairs",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>`,
    description: "From missing slates and cracked tiles to damaged flashing and valley repairs — we diagnose and fix all roof issues quickly and permanently.",
    features: ["Slate & tile replacement", "Lead flashing repairs", "Ridge tile repointing", "Valley gutter repairs", "Storm damage repair", "Leak detection & fix"]
  },
  {
    title: "New Roof Installation",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/></svg>`,
    description: "Complete new roof installations for residential and commercial properties. We use only the highest-quality materials and skilled tradespeople.",
    features: ["Pitched roof installation", "Natural slate roofing", "Concrete & clay tiles", "Timber roof structure", "Breathable membrane", "Full scaffolding included"]
  },
  {
    title: "Flat Roofing",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>`,
    description: "Specialist flat roof installation and repair using the latest materials including EPDM rubber, GRP fibreglass, and high-performance felt systems.",
    features: ["EPDM rubber roofing", "GRP fibreglass roofing", "Torch-on felt roofing", "Flat roof repairs", "Warm roof systems", "Green roof options"]
  },
  {
    title: "Chimney Repairs",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="8" y="2" width="8" height="6"></rect><path d="M4 22V10l8-6 8 6v12H4z"></path></svg>`,
    description: "Complete chimney repair services including repointing, rebuilding, flashing, and cowl installation to prevent leaks and structural damage.",
    features: ["Chimney repointing", "Chimney rebuilding", "Lead flashing renewal", "Chimney cowl fitting", "Stack weatherproofing", "Chimney removal"]
  },
  {
    title: "Guttering & Drainage",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path></svg>`,
    description: "Professional gutter installation, repair, and cleaning services. Protect your property from water damage with properly functioning drainage.",
    features: ["Gutter replacement", "Gutter repair & sealing", "Downpipe installation", "Fascia & soffit boards", "Gutter cleaning", "Cast iron guttering"]
  },
  {
    title: "Emergency Roofing",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>`,
    description: "24/7 emergency roofing services across Manchester. Storm damage, sudden leaks, or structural concerns — we respond within 60 minutes.",
    features: ["60-minute response time", "Temporary weatherproofing", "Storm damage repair", "Emergency tarpaulin", "Insurance claim support", "Same-day permanent fix"]
  }
];
---

<Layout title="Roofing Services Manchester | Roof Repairs Manchester" description="Full range of roofing services in Manchester: repairs, new roofs, flat roofing, chimney repairs, guttering & emergency call-outs. Free quotes available.">
  <Header />

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <h1>Our Roofing Services</h1>
      <p>Professional roofing solutions for every need across Greater Manchester</p>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      {services.map((service, i) => (
        <div class:list={["service-detail", { reverse: i % 2 !== 0 }]}>
          <div class="service-detail-image">
            <div class="service-placeholder">
              <Fragment set:html={service.icon} />
              <span>{service.title}</span>
            </div>
          </div>
          <div class="service-detail-content">
            <h2>{service.title}</h2>
            <div class="red-line"></div>
            <p class="service-desc">{service.description}</p>
            <ul class="service-features">
              {service.features.map(f => (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact/" class="btn btn-red">Get a Free Quote</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--white); font-size: 2rem; text-transform: uppercase; margin-bottom: 10px;">Ready to Get Started?</h2>
      <p style="color: rgba(255,255,255,0.8); margin-bottom: 25px;">Contact us today for a free, no-obligation quote on any roofing service</p>
      <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
        <a href="tel:01612345678" class="btn btn-primary">Call 0161 234 5678</a>
        <a href="/contact/" class="btn btn-outline">Request a Quote</a>
      </div>
    </div>
  </section>

  <Footer />
  <FloatingCTA />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #1a1a2e, #0f3460);
    padding: 80px 0 60px;
    text-align: center;
    color: var(--white);
  }

  .page-hero h1 {
    font-size: 2.8rem;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .page-hero p {
    font-size: 1.15rem;
    color: #ccc;
  }

  .service-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 50px 0;
    border-bottom: 1px solid var(--medium-gray);
  }

  .service-detail:last-child {
    border-bottom: none;
  }

  .service-detail.reverse {
    direction: rtl;
  }

  .service-detail.reverse > * {
    direction: ltr;
  }

  .service-placeholder {
    background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
    border-radius: 12px;
    height: 350px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 15px;
    color: var(--red);
  }

  .service-placeholder span {
    font-family: 'Oswald', sans-serif;
    color: var(--text-gray);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.9rem;
  }

  .service-detail-content h2 {
    font-size: 1.8rem;
    text-transform: uppercase;
  }

  .red-line {
    width: 60px;
    height: 4px;
    background: var(--red);
    margin: 15px 0;
    border-radius: 2px;
  }

  .service-desc {
    color: var(--text-gray);
    line-height: 1.7;
    margin-bottom: 25px;
    font-size: 1rem;
  }

  .service-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 30px;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
  }

  .cta-banner {
    background: var(--red);
    padding: 60px 0;
  }

  @media (max-width: 768px) {
    .service-detail {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .service-detail.reverse {
      direction: ltr;
    }

    .service-features {
      grid-template-columns: 1fr;
    }

    .page-hero h1 {
      font-size: 2rem;
    }
  }
</style>
