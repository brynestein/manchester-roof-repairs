---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import seoData from '../data/seo.json';

const { title, description } = seoData.services;

import servicesData from '../data/services.json';

const serviceIcons: Record<string, string> = {
  "Roof Repairs": `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>`,
  "New Roof Installation": `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/></svg>`,
  "Flat Roofing": `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>`,
  "Chimney Repairs": `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="8" y="2" width="8" height="6"></rect><path d="M4 22V10l8-6 8 6v12H4z"></path></svg>`,
  "Guttering & Drainage": `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path></svg>`,
  "Emergency Roofing": `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>`,
};

const services = servicesData.map((s: { title: string; description: string; features: string[] }) => ({
  ...s,
  icon: serviceIcons[s.title] || serviceIcons["Roof Repairs"],
  image: `/images/service-${s.title.toLowerCase().replace(/[^a-z]+/g, '-')}.webp`,
}));

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Roofing Services by Manchester Gutters",
  "itemListElement": services.map((service, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Service",
      "name": service.title,
      "description": service.description,
      "provider": {
        "@type": "RoofingContractor",
        "name": "Manchester Gutters",
        "url": "https://manchestergutters.co.uk"
      },
      "areaServed": {
        "@type": "City",
        "name": "Manchester"
      }
    }
  }))
};
---

<Layout title={title} description={description} schema={servicesSchema}>
  <Header />

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <h1>Our Roofing Services</h1>
      <p>Professional roofing solutions for every need across Greater Manchester</p>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      {services.map((service, i) => (
        <div class:list={["service-detail", { reverse: i % 2 !== 0 }]}>
          <div class="service-detail-image">
            <img src={service.image} alt={service.title} class="service-photo" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="service-placeholder" style="display:none;">
              <Fragment set:html={service.icon} />
              <span>{service.title}</span>
            </div>
          </div>
          <div class="service-detail-content">
            <h2>{service.title}</h2>
            <div class="red-line"></div>
            <p class="service-desc">{service.description}</p>
            <ul class="service-features">
              {service.features.map(f => (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact/" class="btn btn-red">Get a Free Quote</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--white); font-size: 2rem; text-transform: uppercase; margin-bottom: 10px;">Ready to Get Started?</h2>
      <p style="color: rgba(255,255,255,0.8); margin-bottom: 25px;">Contact us today for a free, no-obligation quote on any roofing service</p>
      <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
        <a href="tel:01612345678" class="btn btn-primary">Call 0161 234 5678</a>
        <a href="/contact/" class="btn btn-outline">Request a Quote</a>
      </div>
    </div>
  </section>

  <Footer />
  <FloatingCTA />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #1a1a2e, #0f3460);
    padding: 80px 0 60px;
    text-align: center;
    color: var(--white);
  }

  .page-hero h1 {
    font-size: 2.8rem;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .page-hero p {
    font-size: 1.15rem;
    color: #ccc;
  }

  .service-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 50px 0;
    border-bottom: 1px solid var(--medium-gray);
  }

  .service-detail:last-child {
    border-bottom: none;
  }

  .service-detail.reverse {
    direction: rtl;
  }

  .service-detail.reverse > * {
    direction: ltr;
  }

  .service-photo {
    width: 100%;
    height: 350px;
    object-fit: cover;
    border-radius: 12px;
  }

  .service-placeholder {
    background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
    border-radius: 12px;
    height: 350px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 15px;
    color: var(--red);
  }

  .service-placeholder span {
    font-family: 'Oswald', sans-serif;
    color: var(--text-gray);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.9rem;
  }

  .service-detail-content h2 {
    font-size: 1.8rem;
    text-transform: uppercase;
  }

  .red-line {
    width: 60px;
    height: 4px;
    background: var(--red);
    margin: 15px 0;
    border-radius: 2px;
  }

  .service-desc {
    color: var(--text-gray);
    line-height: 1.7;
    margin-bottom: 25px;
    font-size: 1rem;
  }

  .service-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 30px;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
  }

  .cta-banner {
    background: var(--red);
    padding: 60px 0;
  }

  @media (max-width: 768px) {
    .service-detail {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .service-detail.reverse {
      direction: ltr;
    }

    .service-features {
      grid-template-columns: 1fr;
    }

    .page-hero h1 {
      font-size: 2rem;
    }
  }
</style>
