---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "name": "Manchester Gutters",
  "url": "https://manchestergutters.co.uk",
  "logo": "https://manchestergutters.co.uk/favicon.svg",
  "image": "https://manchestergutters.co.uk/images/hero-bg.jpg",
  "description": "Professional roof repairs and guttering in Manchester. Fully insured, local roofers with 10-year guarantees. Emergency call-outs, new roofs, flat roofs & more.",
  "telephone": "0161 234 5678",
  "email": "info@manchestergutters.co.uk",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Manchester",
    "addressRegion": "Greater Manchester",
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 53.4808,
    "longitude": -2.2426
  },
  "areaServed": [
    { "@type": "City", "name": "Manchester" },
    { "@type": "City", "name": "Salford" },
    { "@type": "City", "name": "Stockport" },
    { "@type": "City", "name": "Bolton" },
    { "@type": "City", "name": "Bury" },
    { "@type": "City", "name": "Rochdale" },
    { "@type": "City", "name": "Oldham" },
    { "@type": "City", "name": "Wigan" },
    { "@type": "City", "name": "Trafford" },
    { "@type": "City", "name": "Tameside" }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "200",
    "bestRating": "5"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Roofing Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Repairs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "New Roof Installation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Flat Roofing" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Chimney Repairs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Guttering & Drainage" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Emergency Roofing" } }
    ]
  },
  "sameAs": []
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Manchester Gutters",
  "url": "https://manchestergutters.co.uk"
};
---

<Layout schema={[localBusinessSchema, webSiteSchema]}>
  <Header />

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <div class="hero-content">
        <h1>Stop Your Roof Leaking — Fixed Right, First Time</h1>
        <ul class="hero-checks">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yellow)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Fully Insured &amp; Certified Roofers
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yellow)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            10-Year Written Guarantee on All Work
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yellow)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Free No-Obligation Quotes
          </li>
        </ul>
        <div class="hero-buttons">
          <a href="tel:01612345678" class="btn btn-primary">Call Us Now</a>
          <a href="/services/" class="btn btn-outline">Our Services</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number">10+</span>
            <span class="stat-label">Years Experience</span>
          </div>
          <div class="stat">
            <span class="stat-number">2,500+</span>
            <span class="stat-label">Roofs Completed</span>
          </div>
          <div class="stat">
            <span class="stat-number">4.8</span>
            <span class="stat-label">Google Rating</span>
          </div>
        </div>
      </div>
      <div class="hero-form-card">
        <h3>Get Your Free Quote</h3>
        <p>No obligation — we'll get back to you within 2 hours</p>
        <form action="/contact/" method="GET">
          <input type="text" name="name" placeholder="Your Name" required />
          <input type="email" name="email" placeholder="Email Address" required />
          <input type="tel" name="phone" placeholder="Phone Number" required />
          <select name="service">
            <option value="">Select Service</option>
            <option value="roof-repair">Roof Repair</option>
            <option value="new-roof">New Roof Installation</option>
            <option value="flat-roof">Flat Roofing</option>
            <option value="chimney">Chimney Repairs</option>
            <option value="guttering">Guttering</option>
            <option value="emergency">Emergency Roofing</option>
          </select>
          <textarea name="message" placeholder="Describe your roofing issue..." rows="3"></textarea>
          <button type="submit" class="btn btn-primary" style="width: 100%; text-align: center;">Request Free Quote</button>
        </form>
        <p class="form-trust">All work backed by our 10-year guarantee</p>
      </div>
    </div>
    <div class="hero-red-line"></div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <div>
            <strong>Fully Insured</strong>
            <span>£5M Public Liability</span>
          </div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <div>
            <strong>TrustMark Registered</strong>
            <span>Government-Endorsed</span>
          </div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
          </div>
          <div>
            <strong>Checkatrade Approved</strong>
            <span>Vetted &amp; Reviewed</span>
          </div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
          </div>
          <div>
            <strong>10-Year Guarantee</strong>
            <span>Written Warranty</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section why-us" id="about">
    <div class="container">
      <div class="why-us-grid">
        <div class="why-us-image">
          <div class="why-us-image-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/></svg>
            <span>Professional Roofing</span>
          </div>
          <div class="experience-badge">
            <span class="badge-number">10+</span>
            <span class="badge-text">Years of<br/>Experience</span>
          </div>
        </div>
        <div class="why-us-content">
          <h2>Why Manchester Trusts Us With Their Roofs</h2>
          <div class="red-line"></div>
          <p class="why-us-intro">We're not just roofers — we're your neighbours. As a local Manchester roofing company, we take pride in protecting the homes and businesses in our community.</p>

          <div class="outcome-blocks">
            <div class="outcome">
              <div class="outcome-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              </div>
              <div>
                <h4>Permanent Solutions</h4>
                <p>We fix the root cause — not just the symptoms. No quick patches that fail next winter.</p>
              </div>
            </div>
            <div class="outcome">
              <div class="outcome-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
              </div>
              <div>
                <h4>Transparent Pricing</h4>
                <p>Detailed written quotes before any work starts. No hidden costs, no surprises.</p>
              </div>
            </div>
            <div class="outcome">
              <div class="outcome-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <div>
                <h4>Rapid Response</h4>
                <p>Emergency call-outs within 60 minutes. We're always ready when Manchester weather strikes.</p>
              </div>
            </div>
            <div class="outcome">
              <div class="outcome-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
              </div>
              <div>
                <h4>Guaranteed Quality</h4>
                <p>Every job backed by our 10-year written guarantee for complete peace of mind.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="section services-preview" style="background: var(--light-gray);">
    <div class="container">
      <div class="section-header">
        <h2>Our Roofing Services</h2>
        <div class="red-line"></div>
        <p>From small repairs to complete new roofs — we handle it all across Manchester</p>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
          </div>
          <h3>Roof Repairs</h3>
          <p>Expert repairs for leaks, damaged tiles, flashing issues, and storm damage across Manchester.</p>
          <a href="/services/" class="service-link">Learn More &rarr;</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/></svg>
          </div>
          <h3>New Roof Installation</h3>
          <p>Complete new roof installations using premium materials with a 10-year workmanship guarantee.</p>
          <a href="/services/" class="service-link">Learn More &rarr;</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
          </div>
          <h3>Flat Roofing</h3>
          <p>EPDM rubber, GRP fibreglass, and felt flat roof specialists. Long-lasting waterproof solutions.</p>
          <a href="/services/" class="service-link">Learn More &rarr;</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
          </div>
          <h3>Emergency Roofing</h3>
          <p>24/7 emergency roof repairs. We respond within 60 minutes to protect your property.</p>
          <a href="/services/" class="service-link">Learn More &rarr;</a>
        </div>
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <a href="/services/" class="btn btn-red">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="section process-section">
    <div class="container">
      <div class="section-header">
        <h2 style="color: var(--white);">How It Works</h2>
        <div class="red-line"></div>
        <p style="color: #ccc;">Getting your roof fixed is simple — here's our proven 4-step process</p>
      </div>
      <div class="process-grid">
        <div class="process-step">
          <div class="process-number">1</div>
          <h3>Get in Touch</h3>
          <p>Call us or fill in our online form. We'll discuss your roofing needs and arrange a convenient time to visit.</p>
        </div>
        <div class="process-step">
          <div class="process-number">2</div>
          <h3>Free Roof Inspection</h3>
          <p>Our experienced roofer will inspect your roof, identify all issues, and provide a detailed written quote.</p>
        </div>
        <div class="process-step">
          <div class="process-number">3</div>
          <h3>Expert Roofing Work</h3>
          <p>Our skilled team completes the work to the highest standards, keeping your property clean and tidy.</p>
        </div>
        <div class="process-step">
          <div class="process-number">4</div>
          <h3>10-Year Guarantee</h3>
          <p>Receive your written guarantee and enjoy total peace of mind knowing your roof is fully protected.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Preview -->
  <section class="section" style="background: var(--light-gray);">
    <div class="container">
      <div class="section-header">
        <h2>What Our Customers Say</h2>
        <div class="red-line"></div>
        <p>Don't just take our word for it — read reviews from real Manchester homeowners</p>
      </div>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">"Fantastic service from start to finish. They fixed our leaking roof quickly and the price was very fair. Highly recommend to anyone in Manchester."</p>
          <div class="review-author">
            <div class="review-avatar">JB</div>
            <div>
              <strong>James B.</strong>
              <span>Didsbury, Manchester</span>
            </div>
          </div>
        </div>
        <div class="review-card">
          <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">"Called them for an emergency leak during a storm. They arrived within the hour and had it sorted the same day. Brilliant team — can't fault them."</p>
          <div class="review-author">
            <div class="review-avatar">SK</div>
            <div>
              <strong>Sarah K.</strong>
              <span>Chorlton, Manchester</span>
            </div>
          </div>
        </div>
        <div class="review-card">
          <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">"Had a complete new roof fitted. The quality of workmanship is excellent and they left the site spotless. Very professional outfit."</p>
          <div class="review-author">
            <div class="review-avatar">MP</div>
            <div>
              <strong>Mark P.</strong>
              <span>Sale, Manchester</span>
            </div>
          </div>
        </div>
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <a href="/reviews/" class="btn btn-red">Read All Reviews</a>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Areas We Cover</h2>
        <div class="red-line"></div>
        <p>Providing professional roofing services across Greater Manchester</p>
      </div>
      <div class="areas-grid">
        {["Manchester City Centre", "Didsbury", "Chorlton", "Sale", "Altrincham", "Stockport", "Stretford", "Trafford", "Salford", "Bolton", "Bury", "Rochdale", "Oldham", "Wigan", "Tameside", "Ashton-under-Lyne", "Levenshulme", "Withington", "Fallowfield", "Prestwich", "Eccles", "Urmston", "Denton", "Hyde"].map(area => (
          <span class="area-tag">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section faq-section" style="background: var(--light-gray);">
    <div class="container">
      <div class="section-header">
        <h2>Frequently Asked Questions</h2>
        <div class="red-line"></div>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
            How much does roof repair cost in Manchester?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <p>Roof repair costs vary depending on the extent of damage. Minor repairs typically start from £150, while larger jobs can range from £500–£2,000+. We provide free, no-obligation quotes so you know exactly what to expect before any work begins.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
            Are you fully insured?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <p>Yes, we carry £5 million public liability insurance and full employer's liability cover. We're also TrustMark registered and Checkatrade approved, so you can be confident you're in safe hands.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
            Do you offer emergency roofing services?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <p>Absolutely. We offer 24/7 emergency roof repair services across Manchester. In most cases, we can be with you within 60 minutes of your call to make your property safe and watertight.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
            What guarantee do you provide?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <p>All our work comes with a 10-year written guarantee on workmanship. We also use manufacturer-backed materials with their own warranties, giving you double protection and complete peace of mind.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
            What areas of Manchester do you cover?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <p>We cover all of Greater Manchester including Manchester city centre, Didsbury, Chorlton, Sale, Altrincham, Stockport, Salford, Bolton, Bury, Rochdale, Oldham, and all surrounding areas within a 25-mile radius.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2>Need a Roofer in Manchester? Get a Free Quote Today</h2>
        <p>Our friendly team is ready to help — no obligation, no pressure</p>
      </div>
      <div class="cta-actions">
        <a href="tel:01612345678" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;vertical-align:middle;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          0161 234 5678
        </a>
        <a href="/contact/" class="btn btn-outline">Request a Quote</a>
      </div>
    </div>
  </section>

  <Footer />
