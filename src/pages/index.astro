---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'KitchingArt',
  description: 'Original giclee art prints by David Kitching',
  url: 'https://kitchingart.com',
  logo: 'https://kitchingart.com/logo.png',
  founder: {
    '@type': 'Person',
    name: 'David Kitching',
  },
  sameAs: [
    'https://facebook.com/kitchingart',
    'https://instagram.com/kitchingart',
  ],
};
---

<Layout
  title="Original Canvas Art Prints by David Kitching - KitchingArt"
  description="Original giclee canvas art prints from the artist's own website. Abstract, interpretive and photographic works by David Kitching."
  jsonLd={jsonLd}
>
  <!-- Heading section -->
  <section class="hero-heading">
    <div class="container">
      <h1>David Kitching | KitchingArt</h1>
      <p class="hero-heading__subtitle">Original giclee art prints from the artist's own website</p>
    </div>
  </section>

  <!-- Hero slideshow -->
  <section class="hero-slideshow" aria-label="Featured artwork slideshow">
    <div class="slideshow" id="slideshow">
      <div class="slideshow__track">
        <div class="slideshow__slide active" data-slide="0">
          <img src="https://kitchingart.com/cdn/shop/files/Running_through_autumnn_leaves._Large_giclee_canvas..jpg?v=1774296742&width=1920" alt="Running through autumn leaves - Large giclee canvas art print" loading="eager" />
        </div>
        <div class="slideshow__slide" data-slide="1">
          <img src="https://kitchingart.com/cdn/shop/files/Waterfall_s_edge._Large_giclee_art_canvas._Carousel..jpg?v=1774297293&width=1920" alt="Waterfall's edge - Large giclee art canvas" loading="lazy" />
        </div>
        <div class="slideshow__slide" data-slide="2">
          <img src="https://kitchingart.com/cdn/shop/files/The_Organic_Seer._Giclee_art_canvas._Carousel..jpg?v=1774297504&width=1920" alt="The Organic Seer - Giclee art canvas" loading="lazy" />
        </div>
        <div class="slideshow__slide" data-slide="3">
          <img src="https://kitchingart.com/cdn/shop/files/Information_verification._Art_canvas._Carousel..jpg?v=1774297684&width=1920" alt="Information verification - Art canvas" loading="lazy" />
        </div>
        <div class="slideshow__slide" data-slide="4">
          <img src="https://kitchingart.com/cdn/shop/files/Echoes_in_a_ballroom._Giclee_art_canvas._Carousel..jpg?v=1774297886&width=1920" alt="Echoes in a ballroom - Giclee art canvas" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Tagline -->
  <section class="tagline">
    <div class="container">
      <p class="tagline__text">Art for your heart and for your mind</p>
    </div>
  </section>

  <!-- Abstract collection preview -->
  <section class="collection-preview section">
    <div class="container collection-preview__grid">
      <div class="collection-preview__image">
        <img src="https://kitchingart.com/cdn/shop/files/KitchingArt_home_page_abstract_banner.jpg?v=1774295299&width=800" alt="Abstract art collection by David Kitching" loading="lazy" />
      </div>
      <div class="collection-preview__content">
        <h2>Abstract</h2>
        <p>Various takes from just pretty colours to pondering the meaning of life. Bold shapes and colours with different variants to match your existing decor... frameless or with one of two frame styles.</p>
        <a href="/collections?category=abstracts" class="collection-preview__link">More...</a>
      </div>
    </div>
  </section>

  <!-- Interpretive collection preview -->
  <section class="collection-preview collection-preview--reversed section">
    <div class="container collection-preview__grid collection-preview__grid--reversed">
      <div class="collection-preview__content">
        <h2>Interpretive</h2>
        <p>Interpretations of aspects of life and our world.</p>
        <a href="/collections?category=interpretations" class="collection-preview__link">More...</a>
      </div>
      <div class="collection-preview__image">
        <img src="https://kitchingart.com/cdn/shop/files/KitchingArt_David_Kitching_Home_page_Interpretations_banner.jpg?v=1774295426&width=800" alt="Interpretive art collection by David Kitching" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- New Collection (Photographs) -->
  <section class="collection-preview section">
    <div class="container collection-preview__grid">
      <div class="collection-preview__image">
        <img src="https://kitchingart.com/cdn/shop/files/Liberty_statue_Budapest_4.jpg?v=1774296060&width=800" alt="Images of Budapest photography collection" loading="lazy" />
      </div>
      <div class="collection-preview__content">
        <h2>New Collection</h2>
        <p>I've decided to issue my original photographs as canvases too. As of now, the Budapest Collection is the first. But more will follow.</p>
        <p>It's fairly unusual I think, to issue photographs as large giclee prints. Usually they are sold as conventional, framed prints. So I hope you see value in this.</p>
        <a href="/collections/the-images-of-budapest-collection" class="collection-preview__link">Images of Budapest</a>
      </div>
    </div>
  </section>

  <!-- Customer testimonial -->
  <section class="testimonial section">
    <div class="container">
      <div class="testimonial__content">
        <div class="testimonial__image">
          <img src="https://kitchingart.com/cdn/shop/files/Seer_of_the_Matrices_banner_home_page.jpg?v=1774296284&width=800" alt="Seer of the Matrices - canvas art print" loading="lazy" />
        </div>
        <div class="testimonial__text">
          <p class="testimonial__quote">One customer's response to receiving his picture (posted on a public board):</p>
          <blockquote>
            "Just got home and found my picture. It is brilliant, and the packaging superb. If you were thinking of buying something I recommend you do, as they are better in real life than on the website. Thanks David."
          </blockquote>
          <p class="testimonial__author">J.S., Surrey, England.</p>
          <p class="testimonial__artwork">Seer of the Matrices</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Shipping/tariff info -->
  <section class="info-banner section">
    <div class="container">
      <p class="info-banner__main">No import taxes or tariffs in the US, Canada, the UK, the EU, GCC countries, Singapore or Australia. <a href="/shipping">More on shipping destinations here.</a></p>
      <p class="info-banner__detail">Your picture will be produced on demand according to your specification in either the US, Canada, the UK, the EU, Dubai, Singapore or Australia, depending on where you're located.</p>
      <p class="info-banner__personal">(Yes this is still just me. One person. Not a big company.)</p>
    </div>
  </section>

  <!-- Trust section -->
  <section class="trust section--large">
    <div class="container">
      <h2>Trust</h2>
      <div class="trust__content">
        <p>I'm a one man band. Some of my Collections have taken years to finish whilst others were finished in weeks. Most are unrepeatable as they are the result of myriad processes that I could not repeat correctly.</p>
        <p>I want to you to be happy with what arrives at your home. Both the quality and also that you like it and that it becomes a welcoming part of your home, promoting wellbeing and good thoughts for many years to come.</p>
        <p>So yes, I want this quality/ordering/shipping/etc process to go as well as possible for you, because that way I feel good too, and I'm doing my best to ensure this. You can always talk directly to me if you have a problem.</p>
        <p class="trust__signature">David Kitching</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero heading */
  .hero-heading {
    background: var(--color-surface);
    text-align: right;
    padding: 1rem 0;
  }

  .hero-heading h1 {
    font-size: 2.2rem;
    font-weight: 300;
    color: rgba(18, 18, 18, 0.55);
    margin-bottom: 0.25rem;
  }

  .hero-heading__subtitle {
    font-size: 1rem;
    color: rgba(18, 18, 18, 0.45);
  }

  /* Slideshow */
  .hero-slideshow {
    width: 100%;
    overflow: hidden;
  }

  .slideshow__track {
    position: relative;
    width: 100%;
    aspect-ratio: 1.93 / 1;
  }

  .slideshow__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease-in-out;
  }

  .slideshow__slide.active {
    opacity: 1;
  }

  .slideshow__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Tagline */
  .tagline {
    text-align: center;
    padding: 1rem 0;
  }

  .tagline__text {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(18, 18, 18, 0.6);
  }

  /* Collection preview */
  .collection-preview__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .collection-preview__grid--reversed {
    direction: rtl;
  }

  .collection-preview__grid--reversed > * {
    direction: ltr;
  }

  .collection-preview__content h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .collection-preview__content p {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .collection-preview__link {
    display: inline-block;
    color: var(--color-heading-text);
    text-decoration: underline;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .collection-preview__link:hover {
    opacity: 0.7;
  }

  .collection-preview__placeholder {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }

  /* Testimonial */
  .testimonial__content {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: center;
  }

  .testimonial__quote {
    font-style: italic;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  blockquote {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1rem;
    padding-left: 1rem;
    border-left: 3px solid var(--color-border);
  }

  .testimonial__author {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .testimonial__artwork {
    font-style: italic;
    font-size: 0.85rem;
    color: rgba(18, 18, 18, 0.5);
  }

  /* Info banner */
  .info-banner {
    text-align: center;
    padding: 2rem 0;
  }

  .info-banner__main {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .info-banner__main a {
    text-decoration: underline;
  }

  .info-banner__detail {
    margin-bottom: 0.5rem;
  }

  .info-banner__personal {
    font-style: italic;
    font-size: 0.9rem;
  }

  /* Trust */
  .trust {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .trust h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .trust__content p {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .trust__signature {
    font-style: italic;
    font-weight: 600;
    margin-top: 1.5rem;
  }

  @media (max-width: 768px) {
    .collection-preview__grid,
    .collection-preview__grid--reversed,
    .testimonial__content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .collection-preview__grid--reversed {
      direction: ltr;
    }

    .hero-heading h1 {
      font-size: 1.5rem;
    }

    .tagline__text {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  // Simple slideshow
  const slides = document.querySelectorAll('.slideshow__slide');
  let current = 0;

  if (slides.length > 1) {
    setInterval(() => {
      slides[current].classList.remove('active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('active');
    }, 5000);
  }
</script>
