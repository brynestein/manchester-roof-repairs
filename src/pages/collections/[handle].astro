---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollectionByHandle, getCollections } from '../../lib/shopify';

const { handle } = Astro.params;

if (!handle) {
  return Astro.redirect('/collections');
}

let collection: Awaited<ReturnType<typeof getCollectionByHandle>> = null;
let error = '';

try {
  collection = await getCollectionByHandle(handle);
} catch (e) {
  error = 'Unable to load this collection.';
  console.error('Shopify API error:', e);
}

if (!collection && !error) {
  return Astro.redirect('/collections');
}

const products = collection?.products?.edges.map((e) => e.node) || [];
const title = collection?.seo?.title || collection?.title || 'Collection';
const description = collection?.seo?.description || collection?.description || '';

const jsonLd = collection ? {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: collection.title,
  description: collection.description,
  url: `https://kitchingart.com/collections/${handle}`,
} : undefined;
---

<Layout title={`${title} – KitchingArt`} description={description} jsonLd={jsonLd}>
  <section class="collection-page section">
    <div class="container">
      {error ? (
        <div class="error-message">
          <p>{error}</p>
        </div>
      ) : collection && (
        <>
          {/* Collection header with image banner */}
          {collection.image && (
            <div class="collection-banner">
              <img
                src={collection.image.url}
                alt={collection.image.altText || collection.title}
                width={collection.image.width}
                height={collection.image.height}
              />
            </div>
          )}

          <h1>{collection.title}</h1>

          {collection.descriptionHtml && (
            <div class="collection-description" set:html={collection.descriptionHtml} />
          )}

          {products.length > 0 ? (
            <div class="product-grid">
              {products.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
          ) : (
            <p>No products in this collection yet.</p>
          )}
        </>
      )}
    </div>
  </section>
</Layout>

<style>
  .collection-page h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .collection-banner {
    width: 100%;
    aspect-ratio: 3 / 1;
    overflow: hidden;
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  .collection-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-description {
    max-width: 800px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .collection-description :global(p) {
    margin-bottom: 1rem;
  }

  .collection-description :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .collection-description :global(li) {
    margin-bottom: 0.5rem;
  }

  .error-message {
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 4px;
    padding: 1.5rem;
    margin: 2rem 0;
  }
</style>
