---
import Layout from '../../layouts/Layout.astro';
import { getCollections } from '../../lib/shopify';

let collections: Awaited<ReturnType<typeof getCollections>> = [];
let error = '';

try {
  collections = await getCollections();
} catch (e) {
  error = 'Unable to load collections. Please check your Shopify API configuration.';
  console.error('Shopify API error:', e);
}
---

<Layout
  title="All Collections - KitchingArt"
  description="Browse all art collections by David Kitching. Abstract, interpretive and photographic giclee canvas prints."
>
  <section class="collections-page section">
    <div class="container">
      <h1>All Collections</h1>

      {error ? (
        <div class="error-message">
          <p>{error}</p>
          <p>If you're setting up this site, make sure to configure your <code>.env</code> file with valid Shopify Storefront API credentials.</p>
        </div>
      ) : collections.length === 0 ? (
        <p>No collections found.</p>
      ) : (
        <div class="collections-grid">
          {collections.map((collection) => (
            <a href={`/collections/${collection.handle}`} class="collection-card">
              <div class="collection-card__image">
                {collection.image ? (
                  <img
                    src={collection.image.url}
                    alt={collection.image.altText || collection.title}
                    width={collection.image.width}
                    height={collection.image.height}
                    loading="lazy"
                  />
                ) : (
                  <div class="collection-card__placeholder">
                    <span>{collection.title}</span>
                  </div>
                )}
              </div>
              <h2 class="collection-card__title">{collection.title}</h2>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .collections-page h1 {
    font-size: 2rem;
    margin-bottom: 2rem;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .collection-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .collection-card:hover {
    opacity: 0.85;
  }

  .collection-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 2px;
    background: var(--color-surface);
    margin-bottom: 0.75rem;
  }

  .collection-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-body-text);
  }

  .collection-card__title {
    font-size: 1rem;
    font-weight: 500;
  }

  .error-message {
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 4px;
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .error-message code {
    background: rgba(0,0,0,0.05);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-size: 0.9em;
  }

  @media (max-width: 768px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .collections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
