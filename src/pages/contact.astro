---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
---

<Layout title="Contact Us | Manchester Gutters | Free Quotes" description="Get in touch with Manchester Gutters for a free, no-obligation roofing quote. Call 0161 234 5678 or fill in our contact form. We respond within 2 hours.">
  <Header />

  <section class="page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Get in touch for a free, no-obligation quote — we respond within 2 hours</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Form -->
        <div class="contact-form-wrap">
          <h2>Send Us a Message</h2>
          <div class="red-line"></div>
          <p class="form-intro">Fill in the form below and we'll get back to you as soon as possible with a free quote.</p>
          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Full Name *</label>
                <input type="text" id="name" name="name" placeholder="John Smith" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone Number *</label>
                <input type="tel" id="phone" name="phone" placeholder="07XXX XXX XXX" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email Address *</label>
                <input type="email" id="email" name="email" placeholder="john@example.co.uk" required />
              </div>
              <div class="form-group">
                <label for="service">Service Required</label>
                <select id="service" name="service">
                  <option value="">Select a Service</option>
                  <option value="roof-repair">Roof Repair</option>
                  <option value="new-roof">New Roof Installation</option>
                  <option value="flat-roof">Flat Roofing</option>
                  <option value="chimney">Chimney Repairs</option>
                  <option value="guttering">Guttering & Drainage</option>
                  <option value="emergency">Emergency Roofing</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="postcode">Postcode</label>
              <input type="text" id="postcode" name="postcode" placeholder="M20 1XX" />
            </div>
            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="5" placeholder="Please describe your roofing issue or what work you need done..." required></textarea>
            </div>
            <button type="submit" class="btn btn-red" style="width: 100%; text-align: center; font-size: 1.1rem; padding: 16px;">Send Message &amp; Get Free Quote</button>
            <p class="form-note">We'll respond within 2 hours during business hours. Your details are safe with us.</p>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="contact-info">
          <div class="info-card">
            <h3>Contact Details</h3>
            <ul class="info-list">
              <li>
                <div class="info-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </div>
                <div>
                  <strong>Phone</strong>
                  <a href="tel:01612345678">0161 234 5678</a>
                </div>
              </li>
              <li>
                <div class="info-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </div>
                <div>
                  <strong>Email</strong>
                  <a href="mailto:info@manchestergutters.co.uk">info@manchestergutters.co.uk</a>
                </div>
              </li>
              <li>
                <div class="info-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </div>
                <div>
                  <strong>Address</strong>
                  <span>Manchester, Greater Manchester</span>
                </div>
              </li>
              <li>
                <div class="info-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <div>
                  <strong>Opening Hours</strong>
                  <span>Mon–Sat: 8am–6pm</span>
                  <span class="emergency-note">24/7 Emergency Call-Outs</span>
                </div>
              </li>
            </ul>
          </div>

          <div class="info-card emergency-card">
            <h3>Emergency?</h3>
            <p>If you have an urgent roofing emergency, call us now — we're available 24/7 and respond within 60 minutes.</p>
            <a href="tel:01612345678" class="btn btn-primary" style="width: 100%; text-align: center;">
              Call Now: 0161 234 5678
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="map-section">
    <div class="container">
      <div class="map-grid">
        <div class="map-embed">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d75898.2752919917!2d-2.3178429!3d53.4807593!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487a4d4c5226f5db%3A0xd9be143804fe6baa!2sManchester!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk"
            width="100%"
            height="400"
            style="border:0; border-radius: 12px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Manchester Gutters location map"
          ></iframe>
        </div>
        <div class="map-info">
          <h2>Find Us</h2>
          <div class="red-line"></div>
          <p>We're based in Manchester and cover all of Greater Manchester and surrounding areas within a 25-mile radius.</p>
          <p>Whether you're in the city centre, the suburbs, or a neighbouring town, we'll come to you for a free roof inspection and quote.</p>
          <div class="coverage-areas">
            <h4>Key Areas We Cover:</h4>
            <div class="area-tags">
              {["Manchester", "Salford", "Stockport", "Bolton", "Bury", "Rochdale", "Oldham", "Wigan", "Trafford", "Tameside"].map(area => (
                <span class="area-tag">{area}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
  <FloatingCTA />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #1a1a2e, #0f3460);
    padding: 80px 0 60px;
    text-align: center;
    color: var(--white);
  }

  .page-hero h1 {
    font-size: 2.8rem;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .page-hero p {
    font-size: 1.15rem;
    color: #ccc;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 50px;
    align-items: start;
  }

  .contact-form-wrap h2 {
    font-size: 1.8rem;
    text-transform: uppercase;
  }

  .red-line {
    width: 60px;
    height: 4px;
    background: var(--red);
    margin: 15px 0;
    border-radius: 2px;
  }

  .form-intro {
    color: var(--text-gray);
    margin-bottom: 25px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }

  .form-group {
    margin-bottom: 15px;
  }

  .form-group label {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
    margin-bottom: 6px;
    color: var(--dark);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid var(--medium-gray);
    border-radius: 6px;
    font-family: 'Roboto', sans-serif;
    font-size: 0.95rem;
    transition: border-color 0.3s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--red);
  }

  .form-note {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-gray);
    margin-top: 12px;
  }

  .info-card {
    background: var(--light-gray);
    border-radius: 12px;
    padding: 30px;
    margin-bottom: 20px;
  }

  .info-card h3 {
    font-size: 1.3rem;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .info-list li {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
    align-items: flex-start;
  }

  .info-icon {
    width: 45px;
    height: 45px;
    background: var(--white);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--red);
    flex-shrink: 0;
  }

  .info-list strong {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    text-transform: uppercase;
    margin-bottom: 2px;
  }

  .info-list a {
    color: var(--dark);
    transition: color 0.3s;
  }

  .info-list a:hover {
    color: var(--red);
  }

  .info-list span {
    display: block;
    font-size: 0.9rem;
    color: var(--text-gray);
  }

  .emergency-note {
    color: var(--red) !important;
    font-weight: 500;
    font-size: 0.85rem !important;
  }

  .emergency-card {
    background: var(--dark-bg);
    color: var(--white);
  }

  .emergency-card p {
    color: #ccc;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .map-section {
    background: var(--dark-bg);
    padding: 80px 0;
  }

  .map-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .map-info {
    color: var(--white);
  }

  .map-info h2 {
    font-size: 2rem;
    text-transform: uppercase;
  }

  .map-info p {
    color: #ccc;
    line-height: 1.7;
    margin-bottom: 15px;
  }

  .coverage-areas {
    margin-top: 25px;
  }

  .coverage-areas h4 {
    font-size: 1rem;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .area-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .area-tag {
    background: rgba(255, 255, 255, 0.1);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    color: #ccc;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .map-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .page-hero h1 {
      font-size: 2rem;
    }
  }
</style>
